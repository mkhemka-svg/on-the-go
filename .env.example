# ── Supabase ──────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Unsplash (destination + activity images) ──────────────────
# Get a free key at: unsplash.com/developers → New Application
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key-here

# ── Google Places (destination search) ───────────────────────
# Get a key at: console.cloud.google.com → APIs → Places API
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your-google-places-key-here
